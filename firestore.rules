rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is the owner of the path
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Allow the user to read and write their own profile
      allow read, write: if isOwner(userId);

      // Allow the user to read and write any document in any subcollection under their user document
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
